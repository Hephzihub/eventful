<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Cancelled - {{ticketNumber}}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7fa;">
    
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f4f7fa; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #6c757d; padding: 50px 40px; text-align: center;">
                            <h1 style="margin: 0 0 10px 0; color: #ffffff; font-size: 32px; font-weight: 700;">Cancellation Confirmed</h1>
                            <p style="margin: 0; color: #ffffff; font-size: 18px; opacity: 0.9;">Your refund is being processed</p>
                        </td>
                    </tr>

                    <!-- Content -->
                    <tr>
                        <td style="padding: 45px 40px;">
                            
                            <p style="margin: 0 0 10px 0; font-size: 18px; color: #1a1a1a; line-height: 1.6;">
                                Hi <strong style="color: #6c757d;">{{userName}}</strong>,
                            </p>
                            <p style="margin: 0 0 35px 0; font-size: 16px; color: #555555; line-height: 1.7;">
                                Your ticket for <strong>{{eventTitle}}</strong> has been successfully cancelled.
                            </p>

                            <!-- Refund Details Card -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #d4edda; border-left: 5px solid #28a745; border-radius: 12px; margin-bottom: 35px;">
                                <tr>
                                    <td style="padding: 35px;">
                                        <h2 style="margin: 0 0 25px 0; font-size: 22px; color: #155724; font-weight: 700;">💰 Refund Information</h2>
                                        
                                        <table width="100%" cellpadding="14" cellspacing="0" border="0">
                                            <tr>
                                                <td style="font-size: 15px; color: #155724; font-weight: 700; width: 150px;">Ticket Number:</td>
                                                <td style="font-size: 15px; color: #155724; text-align: right; font-family: 'Courier New', monospace;">{{ticketNumber}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #155724; font-weight: 700;">Refund Amount:</td>
                                                <td style="font-size: 22px; color: #155724; font-weight: 800; text-align: right;">{{currency}} {{refundAmount}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #155724; font-weight: 700;">Processing Time:</td>
                                                <td style="font-size: 15px; color: #155724; text-align: right;">{{refundTimeline}}</td>
                                            </tr>
                                        </table>
                                        
                                        <p style="margin: 25px 0 0 0; font-size: 15px; color: #155724; line-height: 1.7;">
                                            The refund will be credited to your original payment method.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- What Happens Next -->
                            <h3 style="margin: 0 0 20px 0; font-size: 20px; color: #1a1a1a; font-weight: 700;">What Happens Next?</h3>
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background: linear-gradient(135deg, #f6f9fc 0%, #f0f4f8 100%); border-radius: 10px; margin-bottom: 35px; border: 1px solid #e1e8ed;">
                                <tr>
                                    <td style="padding: 28px;">
                                        <ul style="margin: 0; padding: 0 0 0 22px; font-size: 15px; color: #555555; line-height: 2.2;">
                                            <li>You'll receive an email once the refund is processed</li>
                                            <li>The amount will appear in your account within {{refundTimeline}}</li>
                                            <li>Your cancelled ticket can no longer be used for entry</li>
                                            <li>You can purchase new tickets if you change your mind</li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>

                            <!-- Feedback -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #e7f3ff; border-left: 5px solid #0066cc; border-radius: 8px;">
                                <tr>
                                    <td style="padding: 25px 28px;">
                                        <p style="margin: 0; font-size: 15px; color: #004085; line-height: 1.7;">
                                            <strong>We're sorry to see you go!</strong> If you have any concerns or feedback about why you cancelled, we'd love to hear from you at <a href="mailto:support@eventful.com" style="color: #0066cc; text-decoration: none; font-weight: 600;">support@eventful.com</a>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #f9fafb; padding: 35px 40px; text-align: center; border-top: 1px solid #e1e8ed;">
                            <p style="margin: 0 0 12px 0; font-size: 14px; color: #555555;">
                                Have questions? We're here to help<br>
                                <a href="mailto:support@eventful.com" style="color: #667eea; text-decoration: none; font-weight: 600;">support@eventful.com</a> | +234 800 000 0000
                            </p>
                            <p style="margin: 0; font-size: 12px; color: #999999;">
                                © {{year}} Eventful. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    
</body>
</html>
