<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Reminder - {{eventTitle}}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7fa;">
    
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f4f7fa; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 50px 40px; text-align: center;">
                            <h1 style="margin: 0 0 10px 0; color: #ffffff; font-size: 36px; font-weight: 700;">⏰ Event Reminder</h1>
                            <p style="margin: 0; color: #ffffff; font-size: 20px; opacity: 0.95; font-weight: 500;">Your event is coming up soon!</p>
                        </td>
                    </tr>

                    <!-- Content -->
                    <tr>
                        <td style="padding: 45px 40px;">
                            
                            <p style="margin: 0 0 10px 0; font-size: 18px; color: #1a1a1a; line-height: 1.6;">
                                Hi <strong style="color: #f5576c;">{{userName}}</strong>,
                            </p>
                            <p style="margin: 0 0 35px 0; font-size: 16px; color: #555555; line-height: 1.7;">
                                This is a friendly reminder that <strong>{{eventTitle}}</strong> is happening soon. Get ready for an amazing time!
                            </p>

                            <!-- Countdown Box -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 15px; margin-bottom: 35px;">
                                <tr>
                                    <td style="padding: 45px 35px; text-align: center;">
                                        <p style="margin: 0 0 12px 0; font-size: 15px; color: #ffffff; opacity: 0.9; text-transform: uppercase; letter-spacing: 2.5px; font-weight: 600;">Starts In</p>
                                        <h2 style="margin: 0; color: #ffffff; font-size: 56px; font-weight: 800; letter-spacing: -1px;">
                                            {{#if (eq hoursUntilEvent 24)}}
                                                Tomorrow!
                                            {{else if (lt hoursUntilEvent 24)}}
                                                {{hoursUntilEvent}}h
                                            {{else}}
                                                {{math hoursUntilEvent "/" 24}} Days
                                            {{/if}}
                                        </h2>
                                        <p style="margin: 15px 0 0 0; font-size: 16px; color: #ffffff; opacity: 0.85;">Don't miss out! 🎊</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Event Info Card -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fff8e1; border-left: 5px solid #ffc107; border-radius: 10px; margin-bottom: 35px;">
                                <tr>
                                    <td style="padding: 30px;">
                                        <h3 style="margin: 0 0 22px 0; font-size: 20px; color: #f57c00; font-weight: 700;">📍 Event Information</h3>
                                        
                                        <table width="100%" cellpadding="10" cellspacing="0" border="0">
                                            <tr>
                                                <td style="font-size: 15px; color: #f57c00; font-weight: 700; width: 90px; vertical-align: top;">Date:</td>
                                                <td style="font-size: 15px; color: #f57c00; line-height: 1.6;">{{eventDate}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #f57c00; font-weight: 700; vertical-align: top;">Time:</td>
                                                <td style="font-size: 15px; color: #f57c00;">{{eventTime}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #f57c00; font-weight: 700; vertical-align: top;">Location:</td>
                                                <td style="font-size: 15px; color: #f57c00; line-height: 1.6;">{{venue}}</td>
                                            </tr>
                                            {{#if meetingLink}}
                                            <tr>
                                                <td style="font-size: 15px; color: #f57c00; font-weight: 700; vertical-align: top;">Join Link:</td>
                                                <td>
                                                    <a href="{{meetingLink}}" style="display: inline-block; background-color: #f57c00; color: #ffffff; text-decoration: none; padding: 10px 20px; border-radius: 6px; font-size: 14px; font-weight: 600;">Click to Join Online →</a>
                                                </td>
                                            </tr>
                                            {{/if}}
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Your Tickets -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background: linear-gradient(135deg, #f6f9fc 0%, #f0f4f8 100%); border-radius: 10px; margin-bottom: 35px; border: 1px solid #e1e8ed;">
                                <tr>
                                    <td style="padding: 28px;">
                                        <h3 style="margin: 0 0 15px 0; font-size: 20px; color: #1a1a1a; font-weight: 700;">🎫 Your Tickets</h3>
                                        <p style="margin: 0; font-size: 15px; color: #555555; line-height: 1.7;">
                                            <strong>Ticket Numbers:</strong> <span style="color: #667eea; font-family: 'Courier New', monospace;">{{ticketNumbers}}</span><br>
                                            <strong>Total Tickets:</strong> {{totalTickets}}
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- What to Bring -->
                            <h3 style="margin: 0 0 20px 0; font-size: 20px; color: #1a1a1a; font-weight: 700;">✅ What to Bring</h3>
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f9fafb; border-radius: 10px; margin-bottom: 35px; padding: 25px 30px;">
                                <tr>
                                    <td>
                                        <ul style="margin: 0; padding: 0 0 0 22px; font-size: 15px; color: #555555; line-height: 2.2;">
                                            <li><strong>Your ticket QR code</strong> (from confirmation email)</li>
                                            <li><strong>Valid photo ID</strong> for verification</li>
                                            <li><strong>Printed or digital copy</strong> of your ticket</li>
                                            <li><strong>Arrive 30 minutes early</strong> for smooth entry</li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 40px 0;">
                                <tr>
                                    <td align="center">
                                        <a href="https://eventful.com/my-tickets" style="display: inline-block; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: #ffffff; text-decoration: none; padding: 17px 50px; border-radius: 35px; font-size: 17px; font-weight: 700; box-shadow: 0 8px 25px rgba(245, 87, 108, 0.4);">View My Tickets</a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Pro Tip -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #e7f3ff; border-left: 5px solid #0066cc; border-radius: 8px; margin: 30px 0 0 0;">
                                <tr>
                                    <td style="padding: 22px 28px;">
                                        <p style="margin: 0; font-size: 15px; color: #004085; line-height: 1.7;">
                                            <strong>💡 Pro Tip:</strong> Screenshot your QR code in case you don't have internet access at the venue!
                                        </p>
                                    </td>
                                </tr>
                            </table>
                            
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #f9fafb; padding: 35px 40px; text-align: center; border-top: 1px solid #e1e8ed;">
                            <p style="margin: 0 0 8px 0; font-size: 18px; color: #1a1a1a; font-weight: 700;">
                                See you there! 🎉
                            </p>
                            <p style="margin: 0 0 15px 0; font-size: 14px; color: #555555;">
                                Questions? Contact <a href="mailto:support@eventful.com" style="color: #667eea; text-decoration: none; font-weight: 600;">support@eventful.com</a>
                            </p>
                            <p style="margin: 0; font-size: 12px; color: #999999;">
                                © {{year}} Eventful. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    
</body>
</html>
