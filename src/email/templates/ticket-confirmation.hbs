<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Tickets - {{eventTitle}}</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7fa;">
    
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f4f7fa; padding: 40px 20px;">
        <tr>
            <td align="center">
                <!-- Main Container -->
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    
                    <!-- Header with Gradient -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 50px 40px; text-align: center;">
                            <h1 style="margin: 0 0 10px 0; color: #ffffff; font-size: 32px; font-weight: 700; letter-spacing: -0.5px;">🎉 Your Tickets Are Ready!</h1>
                            <p style="margin: 0; color: #ffffff; font-size: 18px; opacity: 0.95;">Get ready for an amazing experience</p>
                        </td>
                    </tr>

                    <!-- Content Area -->
                    <tr>
                        <td style="padding: 45px 40px;">
                            
                            <!-- Greeting -->
                            <p style="margin: 0 0 10px 0; font-size: 18px; color: #1a1a1a; line-height: 1.6;">
                                Hi <strong style="color: #667eea;">{{userName}}</strong>,
                            </p>
                            <p style="margin: 0 0 35px 0; font-size: 16px; color: #555555; line-height: 1.7;">
                                Great news! Your tickets for <strong>{{eventTitle}}</strong> have been confirmed. We can't wait to see you there!
                            </p>

                            <!-- Event Details Card -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background: linear-gradient(135deg, #f6f9fc 0%, #f0f4f8 100%); border-radius: 12px; margin-bottom: 35px; border: 1px solid #e1e8ed;">
                                <tr>
                                    <td style="padding: 30px;">
                                        <h2 style="margin: 0 0 25px 0; font-size: 22px; color: #1a1a1a; font-weight: 700;">📅 Event Details</h2>
                                        
                                        <table width="100%" cellpadding="12" cellspacing="0" border="0">
                                            <tr>
                                                <td style="font-size: 15px; color: #888888; width: 110px; vertical-align: top;">Event:</td>
                                                <td style="font-size: 15px; color: #1a1a1a; font-weight: 600;">{{eventTitle}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #888888; vertical-align: top;">Date:</td>
                                                <td style="font-size: 15px; color: #1a1a1a; font-weight: 600;">{{eventDate}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #888888; vertical-align: top;">Time:</td>
                                                <td style="font-size: 15px; color: #1a1a1a; font-weight: 600;">{{eventTime}}</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size: 15px; color: #888888; vertical-align: top;">Location:</td>
                                                <td style="font-size: 15px; color: #1a1a1a; font-weight: 600; line-height: 1.6;">{{venue}}</td>
                                            </tr>
                                            {{#if meetingLink}}
                                            <tr>
                                                <td style="font-size: 15px; color: #888888; vertical-align: top;">Join Online:</td>
                                                <td>
                                                    <a href="{{meetingLink}}" style="color: #667eea; text-decoration: none; font-size: 15px; font-weight: 600; display: inline-block; padding: 8px 16px; background-color: #f0f4ff; border-radius: 6px;">Click to Join →</a>
                                                </td>
                                            </tr>
                                            {{/if}}
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Tickets Heading -->
                            <h2 style="margin: 0 0 25px 0; font-size: 22px; color: #1a1a1a; font-weight: 700;">🎫 Your Tickets ({{totalTickets}})</h2>
                            
                            <!-- Individual Tickets -->
                            {{#each tickets}}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border: 2px solid #e1e8ed; border-radius: 12px; margin-bottom: 25px; overflow: hidden;">
                                <!-- Ticket Header -->
                                <tr>
                                    <td style="background: linear-gradient(90deg, #667eea 0%, #764ba2 100%); padding: 20px 25px;">
                                        <table width="100%">
                                            <tr>
                                                <td>
                                                    <p style="margin: 0; font-size: 20px; color: #ffffff; font-weight: 700;">{{ticketNumber}}</p>
                                                    <p style="margin: 5px 0 0 0; font-size: 14px; color: #ffffff; opacity: 0.9;">{{tierName}}</p>
                                                </td>
                                                <td style="text-align: right;">
                                                    <span style="background-color: rgba(255,255,255,0.25); color: #ffffff; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Valid</span>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                
                                <!-- Ticket Body -->
                                <tr>
                                    <td style="padding: 25px;">
                                        {{#if attendeeName}}
                                        <p style="margin: 0 0 20px 0; font-size: 15px; color: #555555;">
                                            <strong style="color: #1a1a1a;">Attendee:</strong> {{attendeeName}}
                                        </p>
                                        {{/if}}
                                        
                                        <!-- QR Code Section -->
                                        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f9fafb; border-radius: 10px; padding: 25px;">
                                            <tr>
                                                <td align="center">
                                                    <p style="margin: 0 0 20px 0; font-size: 14px; color: #888888; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px;">Scan at Entrance</p>
                                                    <img src="cid:{{qrCid}}" alt="QR Code" style="width: 220px; height: 220px; display: block; border: 4px solid #ffffff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" />
                                                    <p style="margin: 20px 0 0 0; font-size: 13px; color: #888888; line-height: 1.5;">Present this code to event staff</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            {{/each}}

                            <!-- Important Info Alert -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #fff8e1; border-left: 5px solid #ffc107; border-radius: 8px; margin: 35px 0;">
                                <tr>
                                    <td style="padding: 25px 30px;">
                                        <h3 style="margin: 0 0 18px 0; font-size: 18px; color: #f57c00; font-weight: 700;">⚠️ Important Information</h3>
                                        <ul style="margin: 0; padding-left: 22px; color: #f57c00; font-size: 14px; line-height: 1.9;">
                                            <li><strong>Save this email</strong> or screenshot your QR codes</li>
                                            <li><strong>Arrive 30 minutes early</strong> for smooth check-in</li>
                                            <li>Each QR code is <strong>unique and single-use</strong></li>
                                            <li>Bring a <strong>valid photo ID</strong> for verification</li>
                                            <li>Cancellations allowed <strong>up to 24 hours</strong> before event</li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 40px 0 30px 0;">
                                <tr>
                                    <td align="center">
                                        <a href="https://eventful.com/my-tickets" style="display: inline-block; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; text-decoration: none; padding: 16px 45px; border-radius: 30px; font-size: 16px; font-weight: 700; box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4); transition: all 0.3s;">View All My Tickets</a>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #f9fafb; padding: 35px 40px; text-align: center; border-top: 1px solid #e1e8ed;">
                            <p style="margin: 0 0 12px 0; font-size: 14px; color: #555555;">
                                Questions? We're here to help!<br>
                                Email <a href="mailto:support@eventful.com" style="color: #667eea; text-decoration: none; font-weight: 600;">support@eventful.com</a> or call +234 800 000 0000
                            </p>
                            <p style="margin: 15px 0 0 0; font-size: 12px; color: #999999;">
                                © {{year}} Eventful. All rights reserved.<br>
                                <a href="#" style="color: #999999; text-decoration: none;">Privacy Policy</a> | <a href="#" style="color: #999999; text-decoration: none;">Terms of Service</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    
</body>
</html>
